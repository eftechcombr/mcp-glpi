# GLPI API v2.3.0 - OAuth2 configuration
# Copy to .env and fill in your values

# Required: GLPI instance URL (no trailing slash)
GLPI_URL=https://glpi.example.com

# Auth method: password | client_credentials | bearer (default: password)
GLPI_AUTH_METHOD=client_credentials

# ── Password grant (GLPI_AUTH_METHOD=password) ──
# Requires a GLPI OAuth2 client with "Password grant" enabled
# (Setup → OAuth2 Client → edit client → check "Password grant")
GLPI_USERNAME=your_username
GLPI_PASSWORD=your_password
GLPI_CLIENT_ID=your_client_id
# GLPI_CLIENT_SECRET=

# ── Client credentials grant (GLPI_AUTH_METHOD=client_credentials) ──
# Requires a GLPI OAuth2 client with "Client credentials grant" enabled
# GLPI_CLIENT_ID=your_client_id
# GLPI_CLIENT_SECRET=

# ── Bearer token (GLPI_AUTH_METHOD=bearer) ──
# Use a pre-obtained access token directly (skips OAuth2 flow)
# GLPI_ACCESS_TOKEN=your_token

# Optional: Request timeout in milliseconds (default: 15000)
GLPI_TIMEOUT_MS=15000

# Optional: Max retry attempts on 5xx/429 (default: 2)
GLPI_MAX_RETRIES=2

# Optional: Entity/Profile context headers
GLPI_ENTITY_ID=
GLPI_PROFILE_ID=
GLPI_ENTITY_RECURSIVE=false

# Optional: Enable debug logging to stderr
GLPI_DEBUG=false
