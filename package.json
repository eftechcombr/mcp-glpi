{
  "name": "mcp-glpi",
  "version": "3.2.0",
  "description": "MCP Server for GLPI - IT Service Management for Claude. Multi-criteria search, pagination, dynamic field resolution, ticket timeline, ITIL coverage (incidents, problems, changes, validations), asset CMDB, reporting.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-glpi": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "bun run dist/index.js",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build",
    "lint": "eslint src/ test/ scripts/",
    "lint:fix": "eslint src/ test/ scripts/ --fix",
    "test": "bun test",
    "smoke": "bun run scripts/smoke.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "glpi",
    "itsm",
    "itil",
    "helpdesk",
    "service-desk",
    "tickets",
    "incidents",
    "problems",
    "changes",
    "assets",
    "inventory",
    "cmdb",
    "knowledge-base",
    "contracts",
    "projects",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "automation"
  ],
  "author": "GMS64260",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eftechcombr/mcp-glpi.git"
  },
  "bugs": {
    "url": "https://github.com/eftechcombr/mcp-glpi/issues"
  },
  "homepage": "https://github.com/eftechcombr/mcp-glpi#readme",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
