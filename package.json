{
  "name": "mcp-glpi",
  "version": "3.0.0",
  "description": "MCP Server for GLPI - IT Service Management for Claude. Multi-criteria search, pagination, dynamic field resolution, ticket timeline, ITIL coverage (incidents, problems, changes, validations), asset CMDB, reporting.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-glpi": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build",
    "test": "tsx --test test/*.test.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "glpi",
    "itsm",
    "itil",
    "helpdesk",
    "service-desk",
    "tickets",
    "incidents",
    "problems",
    "changes",
    "assets",
    "inventory",
    "cmdb",
    "knowledge-base",
    "contracts",
    "projects",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "automation"
  ],
  "author": "GMS64260",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMS64260/mcp-glpi.git"
  },
  "bugs": {
    "url": "https://github.com/GMS64260/mcp-glpi/issues"
  },
  "homepage": "https://github.com/GMS64260/mcp-glpi#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
